# ServerCTL — Production .env example
# On your server: cp .env.prod.example .env && nano .env && docker compose up -d --build

# Generate tokens with: openssl rand -hex 32
AGENT_TOKEN=REPLACE_WITH_STRONG_TOKEN
DASHBOARD_TOKEN=REPLACE_WITH_STRONG_TOKEN
SECRET_KEY=REPLACE_WITH_STRONG_SECRET

# Your Prometheus URL (optional)
PROMETHEUS_URL=http://10.0.0.1:9090

# Port where the frontend will be available (80 if behind a reverse proxy)
FRONTEND_PORT=80

# Optional: frontend URL for CORS (e.g. https://dashboard.yourdomain.com)
FRONTEND_URL=https://dashboard.yourdomain.com
